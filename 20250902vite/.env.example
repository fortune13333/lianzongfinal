# .env.example — Copy this file to .env and fill in real values.
# The .env file is git-ignored and should NEVER be committed.

# --- 数据库配置 (Database) ---
# 生产部署时设置此变量切换到 PostgreSQL。留空则使用本地 SQLite（开发默认）。
# For production: set to PostgreSQL connection string. Leave empty to use SQLite (dev default).
# DATABASE_URL=postgresql+psycopg2://chaintrace:yourpassword@localhost:5432/chaintrace
# DB_PASSWORD=yourpassword

# (已废弃) Google Gemini API 密钥。V9.0+ 所有AI调用通过后端代理，此字段不再直接使用。
# (Deprecated) Google Gemini API key. All AI calls are proxied through the backend in V9.0+.
API_KEY="YOUR_GEMINI_API_KEY_HERE"

# 前端AI驱动选择。设为 'custom' 以通过后端代理调用AI服务（推荐）。
# Frontend AI driver. Set to 'custom' to proxy AI calls through the backend (recommended).
# Options: custom (recommended) | gemini (deprecated, direct browser call)
VITE_AI_DRIVER=custom

# 后端AI代理接口URL（相对路径，运行时拼接在 agentApiUrl 前）。
# Backend AI proxy endpoint URLs (relative paths, resolved against agentApiUrl at runtime).
VITE_COMMAND_GENERATION_API_URL=/api/ai/generate-command
VITE_CONFIG_CHECK_API_URL=/api/ai/check-config
