# (必需) 用于前端AI辅助功能的 Google Gemini API 密钥。
# V9.0+ 架构更新: 此密钥不再直接用于前端AI功能。所有AI调用都通过后端代理，
# 后端配置请参见 config.ini 文件。
API_KEY="AIzaSyCwVd3milO-Dxy9sA0Lc1_Drlz_ndB7wjE"

# (可选) 选择前端AI驱动。这决定了“AI命令生成”和“AI配置体检”功能使用哪个引擎。
# (Optional) Select the frontend AI driver. This determines which engine is used for "AI Command Generation" and "AI Config Check".
#
# 可选项 (Options):
#   - gemini: (已废弃) 不再支持直接在浏览器调用 Gemini。请使用 'custom'。
#   - custom: (推荐) 通过后端代理调用AI服务。URL应配置为后端代理的相对路径。
VITE_AI_DRIVER=custom

# (可选) 自定义AI服务接口的URL。仅在 VITE_AI_DRIVER = 'custom' 时生效。
# (Optional) Custom URLs for AI services. Only effective when VITE_AI_DRIVER = 'custom'.
VITE_COMMAND_GENERATION_API_URL=/api/ai/generate-command
VITE_CONFIG_CHECK_API_URL=/api/ai/check-config
